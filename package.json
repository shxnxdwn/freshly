{
  "name": "freshly",
  "private": true,
  "version": "1.0.0",
  "description": "Pet project: e-commerce platform",
  "type": "commonjs",
  "homepage": "https://github.com/shxnxdwn/freshly#readme",
  "author": "https://github.com/shxnxdwn/",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shxnxdwn/freshly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shxnxdwn/freshly.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @freshly/backend & npm run dev -w @freshly/frontend",
    "dev:backend": "npm run dev -w @freshly/backend",
    "dev:frontend": "npm run dev -w @freshly/frontend",
    "db:generate": "npm run db:generate -w @freshly/db",
    "db:migrate": "npm run db:migrate -w @freshly/db",
    "db:studio": "npm run db:studio -w @freshly/db"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
